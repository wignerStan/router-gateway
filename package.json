{
  "name": "{{PROJECT_NAME}}-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "{{PROJECT_DESCRIPTION}} - Monorepo Workspace",
  "author": "{{AUTHOR_NAME}} <{{AUTHOR_EMAIL}}>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/{{USERNAME}}/{{PROJECT_NAME}}.git"
  },
  "homepage": "https://github.com/{{USERNAME}}/{{PROJECT_NAME}}#readme",
  "bugs": {
    "url": "https://github.com/{{USERNAME}}/{{PROJECT_NAME}}/issues"
  },
  "keywords": ["typescript", "workspace", "monorepo", "bun"],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "type-check": "bun run --filter '*' type-check",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "clean": "rm -rf packages/*/dist packages/*/node_modules",
    "pre-commit": "lint-staged",
    "pre-push": "bun run type-check && bun run test"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "lint-staged": "^15.2.2",
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs}": ["eslint --fix", "prettier --write"],
    "*.{json,yaml,yml,md}": ["prettier --write"]
  }
}
