{
  "no-dupe-feature-names": "on",
  "no-dupe-scenario-names": "on",
  "no-unnamed-features": "on",
  "no-unnamed-scenarios": "on",
  "no-empty-background": "on",
  "no-empty-file": "on",
  "no-files-without-scenarios": "on",
  "no-background-only-scenario": "on",
  "no-scenario-outlines-without-examples": "on",
  "no-unused-variables": "on",
  "no-examples-in-scenarios": "on",
  "file-name": ["on", {"style": "kebab-case"}],
  "scenario-size": ["on", {"steps-length": {"Background": 4, "Scenario": 7}}],
  "keywords-in-logical-order": "on",
  "only-one-when": "on",
  "use-and": "on",
  "no-restricted-patterns": ["on", {
    "Global": [
      "click",
      "press",
      "type",
      "select",
      "checked",
      "radio",
      "checkbox",
      "dropdown",
      "field",
      "button",
      "link",
      "form",
      "page",
      "url",
      "browser",
      "window",
      "popup",
      "modal",
      "visit",
      "navigate to",
      "database",
      "table",
      "record",
      "row",
      "endpoint",
      "status code",
      "payload",
      "should see",
      "should be",
      "successfully"
    ]
  }],
  "name-length": ["on", {"Feature": 80, "Scenario": 80, "Step": 120}],
  "no-duplicate-tags": "on",
  "no-homogenous-tags": "on",
  "no-superfluous-tags": "on",
  "no-partially-commented-tag-lines": "on",
  "one-space-between-tags": "on",
  "indentation": ["on", {
    "Feature": 0,
    "Background": 2,
    "Scenario": 2,
    "Step": 4,
    "Examples": 4,
    "example": 6,
    "given": 4,
    "when": 4,
    "then": 4,
    "and": 4,
    "but": 4,
    "feature tag": 0,
    "scenario tag": 2
  }],
  "new-line-at-eof": ["on", "yes"],
  "no-multiple-empty-lines": "on",
  "no-trailing-spaces": "on"
}
