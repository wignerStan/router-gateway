# Sample gateway configuration
server:
  port: 3000
  host: "0.0.0.0"
  timeout_secs: 120

credentials:
  - id: anthropic-primary
    provider: anthropic
    api_key: ${ANTHROPIC_API_KEY}
    priority: 10
    allowed_models:
      - claude-3-opus
      - claude-3-5-haiku

  - id: openai-backup
    provider: openai
    api_key: ${OPENAI_API_KEY}
    priority: 5
    allowed_models:
      - gpt-4o

  - id: google-vertex
    provider: google
    api_key: ${GOOGLE_API_KEY}
    priority: 8
    allowed_models:
      - gemini-2.0-flash

routing:
  strategy: weighted
  session_affinity: true
