{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig.json for TypeScript compiler options documentation */

    /* ============================================
       Basic Options
       ============================================ */

    /* Specify ECMAScript target version */
    "target": "ES2022",

    /* Specify module code generation */
    "module": "ESNext",

    /* Specify library files to be included in the compilation */
    "lib": ["ESNext"],

    /* Specify JSX code generation */
    "jsx": "preserve",

    /* ============================================
       Module Resolution Options
       ============================================ */

    /* Specify module resolution strategy */
    "moduleResolution": "bundler",

    /* Detect what modules are imported automatically */
    "moduleDetection": "force",

    /* Base directory for resolving non-relative module names */
    "baseUrl": ".",

    /* Path mapping for module resolution */
    "paths": {
      "@{{PROJECT_SCOPE}}/*": ["./packages/*/src"]
    },

    /* ============================================
       Emit Options
       ============================================ */

    /* Generate .d.ts declaration files */
    "declaration": true,

    /* Generate .d.ts.map source map files */
    "declarationMap": true,

    /* Generate corresponding .map files */
    "sourceMap": true,

    /* Output directory for build artifacts */
    "outDir": "./dist",

    /* Remove comments from output */
    "removeComments": false,

    /* Newline character for output files */
    "newLine": "lf",

    /* Only emit declarations, no JS output */
    "emitDeclarationOnly": false,

    /* ============================================
       Interop Constraints
       ============================================ */

    /* Enable ES module interoperability */
    "esModuleInterop": true,

    /* Allow synthetic default imports */
    "allowSyntheticDefaultImports": true,

    /* Force consistent casing for file names */
    "forceConsistentCasingInFileNames": true,

    /* Ensure each file is a separate module */
    "isolatedModules": true,

    /* Disable verbatim module syntax */
    "verbatimModuleSyntax": false,

    /* Allow accessing UMD globals from modules */
    "allowUmdGlobalAccess": false,

    /* ============================================
       Type Checking
       ============================================ */

    /* Enable all strict type checking options */
    "strict": true,

    /* Error on implicit any types */
    "noImplicitAny": true,

    /* Enable strict null checks */
    "strictNullChecks": true,

    /* Enable strict function type checking */
    "strictFunctionTypes": true,

    /* Enable strict bind/call/apply checking */
    "strictBindCallApply": true,

    /* Check class property initialization */
    "strictPropertyInitialization": true,

    /* Error on implicit this types */
    "noImplicitThis": true,

    /* Parse in strict mode and emit 'use strict' */
    "alwaysStrict": true,

    /* Error on unused local variables */
    "noUnusedLocals": true,

    /* Error on unused parameters */
    "noUnusedParameters": true,

    /* Use exact optional property types */
    "exactOptionalPropertyTypes": true,

    /* Error on functions with code paths that don't return */
    "noImplicitReturns": true,

    /* Error on fallthrough in switch statements */
    "noFallthroughCasesInSwitch": true,

    /* Add 'undefined' to types when accessing unknown index */
    "noUncheckedIndexedAccess": true,

    /* Error when override methods aren't explicitly marked */
    "noImplicitOverride": true,

    /* Disallow property access on index signatures */
    "noPropertyAccessFromIndexSignature": true,

    /* Disallow unused labels */
    "allowUnusedLabels": false,

    /* Disallow unreachable code */
    "allowUnreachableCode": false,

    /* ============================================
       Completeness
       ============================================ */

    /* Skip type checking of default library declaration files */
    "skipDefaultLibCheck": false,

    /* Skip type checking of all declaration files */
    "skipLibCheck": true,

    /* ============================================
       Decorators
       ============================================ */

    /* Enable experimental support for decorators */
    "experimentalDecorators": true,

    /* Emit design-type metadata for decorated declarations */
    "emitDecoratorMetadata": true,

    /* ============================================
       Other Options
       ============================================ */

    /* Allow importing .ts files */
    "allowImportingTsExtensions": true,

    /* Allow JavaScript files in compilation */
    "allowJs": true,

    /* Type check JavaScript files */
    "checkJs": false,

    /* Enable importing .json files */
    "resolveJsonModule": true,

    /* Provide full support for iterables in for-of loops */
    "downlevelIteration": true,

    /* Type declaration files to be included in compilation */
    "types": [
      "bun-types",
      "node"
    ]
  },
  "files": [],
  "include": [],
  "exclude": [],
  "references": []
}
