# Environment Configuration Example
# Copy this file to .env and adjust values as needed

# ============================================
# Application Configuration
# ============================================
APP_NAME={{PROJECT_NAME}}
APP_ENV=development
APP_VERSION=1.0.0

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_WORKERS=4

# ============================================
# Logging Configuration
# ============================================
# Log level: trace, debug, info, warn, error
LOG_LEVEL=debug
# Log format: json, pretty, compact
LOG_FORMAT=pretty
# Log to file (optional)
LOG_FILE=

# ============================================
# Database Configuration (if needed)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_MAX_CONNECTIONS=10
# DATABASE_MIN_CONNECTIONS=1

# ============================================
# Redis Configuration (if needed)
# ============================================
# REDIS_URL=redis://localhost:6379
# REDIS_MAX_CONNECTIONS=10

# ============================================
# OpenTelemetry / Tracing Configuration
# ============================================
# Enable distributed tracing
OTEL_ENABLED=false
# Exporter: jaeger, otlp
OTEL_EXPORTER=jaeger
# Jaeger endpoint
OTEL_JAEGER_ENDPOINT=http://localhost:14268/api/traces
# Service name for tracing
OTEL_SERVICE_NAME={{PROJECT_NAME}}

# ============================================
# Metrics Configuration
# ============================================
# Enable metrics
METRICS_ENABLED=true
# Metrics port
METRICS_PORT=9090
# Metrics path
METRICS_PATH=/metrics

# ============================================
# Security Configuration
# ============================================
# Secret key (generate with: openssl rand -base64 32)
SECRET_KEY={{SECRET_KEY}}
# JWT expiration (in seconds)
JWT_EXPIRATION=3600

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ============================================
# Feature Flags
# ============================================
# Enable experimental features
FEATURE_EXPERIMENTAL=false
# Enable debug endpoints
FEATURE_DEBUG_ENDPOINTS=true

# ============================================
# Development Configuration
# ============================================
# Enable hot reload
HOT_RELOAD=true
# Enable debug mode
DEBUG=true

# ============================================
# Testing Configuration
# ============================================
# Test database URL (if needed)
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/test_db
# Test Redis URL (if needed)
# TEST_REDIS_URL=redis://localhost:6379/1
